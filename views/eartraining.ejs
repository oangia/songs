<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ear Training</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        html, body {
            width: 100%;
            height: 100%;
        }
        
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            background: #f0f0f0;
            overflow: hidden;
            padding: 20px;
        }
        
        .iframe-container {
            position: relative;
            width: 100%;
            height: 100%;
            max-width: 428px;
            max-height: calc(100vh - 40px);
            overflow: hidden;
            border-radius: 20px;
        }
        
        iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
            display: block;
        }
        
        /* Mobile devices - full screen */
        @media (max-width: 480px) {
            body {
                padding: 0;
            }
            
            .iframe-container {
                max-width: 100%;
                max-height: 100vh;
                border-radius: 0;
            }
        }
    </style>
</head>
<body>
    <div class="iframe-container">
        <iframe src="https://theeartraining.web.app/" title="Ear Training App"></iframe>
    </div>
</body>
</html>
